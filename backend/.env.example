# ========== General ==========
APP_NAME=springboot-template
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/

# ========== Frontend / CORS ==========
FRONTEND_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_HEADERS=*
APP_CORS_EXPOSED_HEADERS=Authorization,Content-Disposition
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_MAX_AGE=3600

# ========== Swagger / OpenAPI (Global) ==========
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_API_DOCS_PATH=/v3/api-docs
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html
SPRINGDOC_SWAGGER_UI_SORTER=alpha

# ========== Swagger / OpenAPI (Per Profile) ==========
SPRINGDOC_API_DOCS_ENABLED_DEV=true
SPRINGDOC_API_DOCS_ENABLED_TEST=true
SPRINGDOC_API_DOCS_ENABLED_PROD=true
SPRINGDOC_SWAGGER_UI_ENABLED_PROD=false

# ========== Swagger Info ==========
APP_SWAGGER_TITLE=Spring Boot Template API
APP_SWAGGER_VERSION=v1
APP_SWAGGER_DESCRIPTION=Base architecture for reusable Spring Boot projects
APP_SWAGGER_DESCRIPTION_DEV=API docs for development environment
APP_SWAGGER_DESCRIPTION_TEST=API docs for test environment
APP_SWAGGER_DESCRIPTION_PROD=API docs for production environment
APP_SWAGGER_CONTACT_NAME=Backend Team
APP_SWAGGER_CONTACT_EMAIL=backend@example.com

# ========== JWT ==========
APP_JWT_SECRET=VGhpc0lzQVRlbXBsYXRlSldUU2VjcmV0S2V5U2hvdWxkQmVBdExlYXN0MzJCeXRlcw==
APP_JWT_ACCESS_TOKEN_EXPIRATION_MS=86400000

# ========== Logging ==========
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG
LOGGING_LEVEL_ROOT_DEV=INFO
LOGGING_LEVEL_APP_DEV=DEBUG
LOGGING_LEVEL_ROOT_TEST=INFO
LOGGING_LEVEL_APP_TEST=DEBUG
LOGGING_LEVEL_ROOT_PROD=WARN
LOGGING_LEVEL_APP_PROD=INFO
